                        else{
                            user_li[k].style.display='block';
                            user_li[k].style.boxShadow='#fff 0 0 0 1px inset, red 0 0 0 3px inset'; }}
                    else{
                        user_li[k].style.boxShadow='none'; }}}}

        blue_user_dia(); }
