            for(k=0; k<user_li.length; k++){ // ダイアログのリストのマスク
                if(user_li[k].querySelector('a')){
                    user_href[k]=user_li[k].querySelector('a').getAttribute('href');
                    if(block_regex_id.test(user_href[k])==true){
